# Required by the vekan-app Railway service.
# Paste these keys into Railway -> vekan-app -> Variables -> RAW Editor.
# Replace both JWT placeholders with different random values and never commit real secrets.

NODE_ENV=production
JWT_ACCESS_SECRET=<generate-a-long-random-secret>
JWT_REFRESH_SECRET=<generate-a-different-long-random-secret>

# REQUIRED: use this exact plain-text hostname. Do not replace it with an
# unresolved Railway reference. It requires a second service named exactly
# "rethinkdb" in the same Railway project and environment.
RETHINKDB_SERVERS=rethinkdb.railway.internal:28015
RETHINKDB_DB=vekan
RETHINKDB_USER=admin
RETHINKDB_TIMEOUT=20
RETHINKDB_INIT_MAX_ATTEMPTS=60
RETHINKDB_INIT_RETRY_MS=2000

# Generate a public domain for vekan-app, then replace this placeholder.
CORS_ORIGIN=https://<your-generated-railway-domain>

# Required for account invitations, password setup, and verified email changes.
APP_PUBLIC_URL=https://vekaninvoicegenerator-production.up.railway.app
RESEND_API_KEY=<create-and-store-a-new-resend-api-key>
EMAIL_FROM=Vekan Tech <accounts@your-verified-sending-domain.com>
ACCOUNT_TOKEN_EXPIRY_MINUTES=60
